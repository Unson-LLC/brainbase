{
  "name": "@unson/brainbase-mcp",
  "version": "0.1.0",
  "description": "Local-first Brainbase MCP server and personal onboarding kit.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "brainbase-mcp": "dist/index.js",
    "brainbase": "dist/cli.js"
  },
  "files": [
