{
  "compilerOptions": {
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true
  },
  "include": [
    "modules/core/*.js",
    "modules/ui-helpers.js",
    "modules/utils/*.js",
    "modules/domain/**/*.js"
  ],
  "exclude": ["../node_modules"]
}
